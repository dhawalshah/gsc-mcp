# ── Google OAuth (required for HTTP server mode) ─────────────────────────────
# You can either set the client ID/secret directly (preferred for Cloud Run)…
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# …or point to a downloaded client_secret.json from Google Cloud Console.
# Set ONE of {GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET} or OAUTH_CONFIG_PATH.
OAUTH_CONFIG_PATH=./client_secret.json

# Where Google should redirect after the user signs in.
# Defaults to ${BASE_URL}/auth/callback if unset.
# GOOGLE_REDIRECT_URI=http://localhost:8080/auth/callback

# ── Server identity ──────────────────────────────────────────────────────────
# Public URL where this service is reachable. Used for OAuth metadata
# (issuer, authorization_endpoint, token_endpoint) and the canonical
# resource URI MCP clients bind their tokens to.
# Local dev: http://localhost:8080
# Cloud Run: https://your-service-xxxx.run.app
BASE_URL=http://localhost:8080

# ── Firestore (token storage) ────────────────────────────────────────────────
# GCP project hosting the Firestore database. Required for HTTP server mode.
# Not required for local STDIO mode (setup_local_auth.py).
GCP_PROJECT_ID=

# ── Access control (optional) ────────────────────────────────────────────────
# Comma-separated list of email domains permitted to authenticate.
# Empty/unset = anyone with a Google account may connect.
# Example: ALLOWED_DOMAINS=acme.com,beta.example
ALLOWED_DOMAINS=

# ── Local STDIO mode only ────────────────────────────────────────────────────
# Set in your Claude Desktop MCP config, NOT here.
# MCP_USER_EMAIL=you@yourcompany.com

# ── Server tuning ────────────────────────────────────────────────────────────
# PORT=8080
# LOG_LEVEL=INFO

# Defensively allow Google to return a superset of requested OAuth scopes.
# Required when the OAuth client has prior consents for broader scopes,
# otherwise google-auth-oauthlib raises "Scope has changed" in /auth/callback.
OAUTHLIB_RELAX_TOKEN_SCOPE=1
